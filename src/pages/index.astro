---
import { ArrowRight, Instagram, Mail, MapPin, Phone } from "lucide-react";
import Layout from "../layouts/Layout.astro";
import { businessUnits, homePage, siteCopy, siteSettings } from "../lib/cms";

const pageTitle = homePage.seoTitle;
const pageDescription = homePage.seoDescription;
const contactItems = [
	{ type: "phone", label: siteCopy.home.contactPhoneLabel, value: siteSettings.phoneDisplay, href: siteSettings.phoneHref },
	{ type: "email", label: siteCopy.home.contactEmailLabel, value: siteSettings.email, href: `mailto:${siteSettings.email}` },
	{ type: "instagram", label: siteCopy.home.contactInstagramLabel, value: siteSettings.instagram.label, href: siteSettings.instagram.url },
	{ type: "location", label: siteCopy.home.contactLocationLabel, value: siteSettings.location },
];
---

<Layout title={pageTitle} description={pageDescription} canonicalPath="/" image={homePage.seoImage}>
	<main class="min-h-[100svh] bg-[#d9d9d9] text-azento-900">
		<section class="relative overflow-hidden bg-[#d9d9d9]">
			<div class="pointer-events-none absolute inset-x-0 top-0 flex justify-center opacity-[0.7]" aria-hidden="true">
				<img src={siteSettings.lightLogo.src} alt="" class="mt-0 h-[15rem] w-[15rem] object-contain sm:h-[17rem] sm:w-[17rem]" />
			</div>

			<header class="relative z-20 flex items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
				<a href="/" class="inline-flex rounded-lg border border-neutral-200 bg-white p-1.5 shadow-sm" aria-label={`${siteSettings.companyName}, ${siteCopy.home.logoAriaSuffix}`}>
					<img src={siteSettings.logo.src} alt={siteSettings.logo.alt} class="h-14 w-14 object-contain sm:h-16 sm:w-16" />
				</a>
				<div class="hidden items-center gap-5 text-sm font-medium text-azento-700 sm:flex">
					<a href={siteSettings.phoneHref} class="transition-colors hover:text-accent-700">{siteSettings.phoneDisplay}</a>
					<a href={`mailto:${siteSettings.email}`} class="transition-colors hover:text-accent-700">{siteSettings.email}</a>
				</div>
			</header>

			<div class="relative z-10 px-4 pt-12 pb-12 sm:px-6 sm:pt-16 lg:px-8 lg:pt-24 lg:pb-16">
				<div class="mx-auto w-full max-w-7xl pb-6 text-center lg:pb-8">
					<p class="mb-2 text-base font-semibold uppercase tracking-widest text-accent-700 sm:text-lg">{homePage.eyebrow}</p>
					<h1 class="font-display text-3xl font-semibold leading-tight text-azento-900 sm:text-4xl lg:text-5xl">
						{homePage.title}
					</h1>
					<p class="mx-auto mt-2 max-w-2xl text-sm leading-relaxed text-azento-700 sm:text-base">
						{homePage.intro}
					</p>
				</div>

				<div class="mx-auto grid w-full max-w-7xl gap-4 lg:grid-cols-2">
					{businessUnits.map((unit) => (
						<a
							href={unit.slug}
							class="group relative flex min-h-[22rem] overflow-hidden rounded-lg border-2 border-accent-500 bg-azento-900 shadow-[0_0_0_4px_rgba(196,168,130,0.22)] focus-visible:outline-accent-700 lg:min-h-[30rem]"
							aria-label={`${siteCopy.home.discoverAriaPrefix} ${unit.name}`}
						>
							<img
								src={unit.selectorImage}
								alt={unit.selectorAlt}
								class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
								loading="eager"
							/>
							<div class:list={["absolute inset-0", unit.tone === "wood" ? "bg-gradient-to-t from-accent-950/95 via-accent-950/45 to-neutral-950/10" : "bg-gradient-to-t from-azento-950/95 via-azento-950/50 to-neutral-950/10"]}></div>

							<div class="relative z-10 mt-auto max-w-xl p-6 sm:p-8 lg:p-10">
								<p class="mb-2 text-xs font-semibold uppercase tracking-widest text-white/65">{homePage.cardEyebrow}</p>
								<h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">{unit.name}</h2>
								<p class="mt-3 max-w-lg text-sm leading-relaxed text-white/80 sm:text-base">{unit.selectorDescription}</p>
								<span class="mt-5 inline-flex items-center gap-3 font-semibold text-white">
									{homePage.cardCtaPrefix} {unit.shortName}
									<ArrowRight size={19} className="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" />
								</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="contacto" class="bg-white py-16 sm:py-20 bg-[#d9d9d9]">
			<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
				<div class="mb-8 text-center">
					<p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-700 sm:text-sm">{homePage.contactEyebrow}</p>
					<h2 class="font-display text-3xl font-semibold text-azento-800 sm:text-4xl">{homePage.contactTitle}</h2>
				</div>

				<div class="grid gap-4 md:grid-cols-2">
					{contactItems.map((item) => (
						item.href ? (
							<a
								href={item.href}
								target={item.type === "instagram" ? "_blank" : undefined}
								rel={item.type === "instagram" ? "noopener noreferrer" : undefined}
								class="group flex min-h-24 items-center gap-4 rounded-2xl border border-neutral-200 bg-neutral-50 p-4 shadow-sm transition-colors hover:border-azento-200 hover:bg-white sm:p-5"
							>
								<span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-azento-700 text-white transition-colors group-hover:bg-azento-600 sm:h-16 sm:w-16">
									{item.type === "phone" && <Phone size={25} aria-hidden="true" />}
									{item.type === "email" && <Mail size={25} aria-hidden="true" />}
									{item.type === "instagram" && <Instagram size={25} aria-hidden="true" />}
								</span>
								<span class="min-w-0">
									<span class="block text-sm font-medium text-azento-500 sm:text-base">{item.label}</span>
									<span class="mt-1 block break-words text-lg font-semibold leading-tight text-azento-800 sm:text-xl">{item.value}</span>
								</span>
							</a>
						) : (
							<div class="flex min-h-24 items-center gap-4 rounded-2xl border border-neutral-200 bg-neutral-50 p-4 shadow-sm sm:p-5">
								<span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-azento-700 text-white sm:h-16 sm:w-16">
									<MapPin size={25} aria-hidden="true" />
								</span>
								<span class="min-w-0">
									<span class="block text-sm font-medium text-azento-500 sm:text-base">{item.label}</span>
									<span class="mt-1 block break-words text-lg font-semibold leading-tight text-azento-800 sm:text-xl">{item.value}</span>
								</span>
							</div>
						)
					))}
				</div>
			</div>
		</section>

		<footer class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 border-t border-neutral-200 bg-white px-4 py-5 text-xs text-azento-500 sm:justify-between sm:px-6 lg:px-8">
			<span>© {new Date().getFullYear()} {siteSettings.companyName}</span>
			<nav aria-label={siteCopy.home.legalNavLabel} class="flex flex-wrap justify-center gap-4">
				<a href="/aviso-legal" class="hover:text-azento-800">{siteCopy.footer.legalNoticeLabel}</a>
				<a href="/politica-privacidad" class="hover:text-azento-800">{siteCopy.footer.privacyLabel}</a>
				<a href="/politica-cookies" class="hover:text-azento-800">{siteCopy.footer.cookiesLabel}</a>
			</nav>
		</footer>
	</main>
</Layout>
