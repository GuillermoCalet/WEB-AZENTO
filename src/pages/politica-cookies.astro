---
import LegalPage from "../components/LegalPage.astro";
import { legalPages } from "../lib/cms";
---

<LegalPage page={legalPages.cookiePolicy} canonicalPath="/politica-cookies" actionButtonId="open-cookie-config" />

<script>
  document.getElementById("open-cookie-config")?.addEventListener("click", () => {
    const modal = document.getElementById("cookie-modal");
    if (modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
  });
</script>
