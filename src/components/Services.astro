---
import { ArrowUpRight } from "lucide-react";
import type { BusinessUnitConfig } from "../data/businessUnits";

interface Props {
	unit: BusinessUnitConfig;
}

const { unit } = Astro.props;
const isWood = unit.tone === "wood";
---

<section id="servicios" class:list={["py-20 sm:py-24 lg:py-28", isWood ? "bg-accent-50" : "bg-neutral-100"]}>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end lg:gap-16">
			<div>
				<p class:list={["mb-4 text-sm font-semibold uppercase tracking-widest", isWood ? "text-accent-700" : "text-azento-600"]}>
					Servicios
				</p>
				<h2 class="font-display text-3xl font-semibold leading-tight text-azento-800 sm:text-4xl lg:text-5xl">
					{unit.servicesTitle}
				</h2>
			</div>
			<p class="max-w-2xl text-lg leading-relaxed text-neutral-600 lg:justify-self-end">
				{unit.servicesDescription}
			</p>
		</div>

		<div class="mt-12 grid gap-px overflow-hidden rounded-lg border border-neutral-200 bg-neutral-200 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3">
			{unit.services.map((service, index) => (
				service.href ? (
					<a href={service.href} class="group min-h-64 bg-white p-7 transition-colors hover:bg-neutral-50 sm:p-8" aria-label={`Más información sobre ${service.title}`}>
						<div class="flex items-start justify-between gap-5">
							<span class:list={["text-sm font-bold", isWood ? "text-accent-700" : "text-azento-600"]}>{String(index + 1).padStart(2, "0")}</span>
							<ArrowUpRight size={20} className="text-neutral-400 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" aria-hidden="true" />
						</div>
						<h3 class="mt-10 font-display text-2xl font-semibold text-azento-800">{service.title}</h3>
						<p class="mt-4 leading-relaxed text-neutral-600">{service.description}</p>
					</a>
				) : (
					<article class="min-h-64 bg-white p-7 sm:p-8">
						<span class:list={["text-sm font-bold", isWood ? "text-accent-700" : "text-azento-600"]}>{String(index + 1).padStart(2, "0")}</span>
						<h3 class="mt-10 font-display text-2xl font-semibold text-azento-800">{service.title}</h3>
						<p class="mt-4 leading-relaxed text-neutral-600">{service.description}</p>
					</article>
				)
			))}
		</div>
	</div>
</section>
