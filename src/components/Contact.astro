---
import { Instagram, Mail, MapPin, Phone, Send } from "lucide-react";
import { siteSettings, type BusinessUnitConfig } from "../lib/cms";

interface Props {
	unit: BusinessUnitConfig;
}

const { unit } = Astro.props;
const isWood = unit.tone === "wood";

const contactInfo = [
	{ type: "phone", label: "Teléfono", value: siteSettings.phoneDisplay, href: siteSettings.phoneHref },
	{ type: "email", label: "Correo", value: siteSettings.email, href: `mailto:${siteSettings.email}` },
	{ type: "instagram", label: "Instagram", value: siteSettings.instagram.label, href: siteSettings.instagram.url },
	{ type: "location", label: "Zona de trabajo", value: siteSettings.location },
];
---

<section id="contacto" class="bg-neutral-100 py-20 sm:py-24 lg:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
			<div>
				<p class:list={["mb-4 text-sm font-semibold uppercase tracking-widest", isWood ? "text-accent-700" : "text-azento-600"]}>Contacto</p>
				<h2 class="font-display text-3xl font-semibold leading-tight text-azento-800 sm:text-4xl lg:text-5xl">
					{unit.formTitle}
				</h2>
				<p class="mt-6 max-w-xl text-lg leading-relaxed text-neutral-600">{unit.formDescription}</p>

				<div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
					{contactInfo.map((info) => (
						info.href ? (
							<a href={info.href} target={info.type === "instagram" ? "_blank" : undefined} rel={info.type === "instagram" ? "noopener noreferrer" : undefined} class="group flex min-h-16 items-center gap-4 rounded-lg border border-neutral-200 bg-white p-4 transition-colors hover:border-neutral-300">
								<span class:list={["flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-white", isWood ? "bg-accent-700" : "bg-azento-700"]}>
									{info.type === "phone" && <Phone size={19} aria-hidden="true" />}
									{info.type === "email" && <Mail size={19} aria-hidden="true" />}
									{info.type === "instagram" && <Instagram size={19} aria-hidden="true" />}
								</span>
								<span class="min-w-0">
									<span class="block text-xs font-medium uppercase tracking-widest text-neutral-500">{info.label}</span>
									<span class="mt-1 block break-words font-semibold text-azento-800">{info.value}</span>
								</span>
							</a>
						) : (
							<div class="flex min-h-16 items-center gap-4 rounded-lg border border-neutral-200 bg-white p-4">
								<span class:list={["flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-white", isWood ? "bg-accent-700" : "bg-azento-700"]}>
									<MapPin size={19} aria-hidden="true" />
								</span>
								<span>
									<span class="block text-xs font-medium uppercase tracking-widest text-neutral-500">{info.label}</span>
									<span class="mt-1 block font-semibold text-azento-800">{info.value}</span>
								</span>
							</div>
						)
					))}
				</div>
			</div>

			<div id="presupuesto" class="scroll-mt-24 rounded-lg border border-neutral-200 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
				<h3 class="font-display text-2xl font-semibold text-azento-800">Solicita tu presupuesto</h3>
				<p class="mt-2 text-sm leading-relaxed text-neutral-500">Los campos marcados con * son obligatorios.</p>

				<form class="mt-8 space-y-5" data-quote-form>
					<input type="hidden" name="business_unit" value={unit.id} />
					<input type="hidden" name="source_page" value={unit.slug} />
					<input type="hidden" name="source_url" value="" data-source-url />

					<div class="absolute -left-[9999px]" aria-hidden="true">
						<label for="website">No rellenar este campo</label>
						<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<div>
							<label for="name" class="mb-2 block text-sm font-medium text-azento-700">Nombre completo *</label>
							<input type="text" id="name" name="name" autocomplete="name" maxlength="100" placeholder="Tu nombre" class="w-full rounded-lg border border-neutral-300 bg-white px-4 py-3 text-azento-800 placeholder:text-neutral-400 focus:border-azento-500 focus:ring-2 focus:ring-azento-500/20" required />
						</div>
						<div>
							<label for="email" class="mb-2 block text-sm font-medium text-azento-700">Correo electrónico *</label>
							<input type="email" id="email" name="email" autocomplete="email" maxlength="254" placeholder="tu@email.com" class="w-full rounded-lg border border-neutral-300 bg-white px-4 py-3 text-azento-800 placeholder:text-neutral-400 focus:border-azento-500 focus:ring-2 focus:ring-azento-500/20" required />
						</div>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						<div>
							<label for="phone" class="mb-2 block text-sm font-medium text-azento-700">Teléfono</label>
							<input type="tel" id="phone" name="phone" autocomplete="tel" inputmode="tel" maxlength="30" placeholder="+34 600 000 000" class="w-full rounded-lg border border-neutral-300 bg-white px-4 py-3 text-azento-800 placeholder:text-neutral-400 focus:border-azento-500 focus:ring-2 focus:ring-azento-500/20" />
						</div>
						<div>
							<label for="service" class="mb-2 block text-sm font-medium text-azento-700">Servicio de interés *</label>
							<select id="service" name="service" class="w-full rounded-lg border border-neutral-300 bg-white px-4 py-3 text-azento-800 focus:border-azento-500 focus:ring-2 focus:ring-azento-500/20" required>
								<option value="">Selecciona un servicio</option>
								{unit.formServices.map((service) => <option value={service.value}>{service.label}</option>)}
							</select>
						</div>
					</div>

					<div>
						<label for="message" class="mb-2 block text-sm font-medium text-azento-700">Cuéntanos tu proyecto</label>
						<textarea id="message" name="message" rows="5" maxlength="2000" placeholder="Describe brevemente el espacio y qué tienes en mente..." class="w-full resize-y rounded-lg border border-neutral-300 bg-white px-4 py-3 text-azento-800 placeholder:text-neutral-400 focus:border-azento-500 focus:ring-2 focus:ring-azento-500/20"></textarea>
					</div>

					<div class="flex items-start gap-3 rounded-lg border border-neutral-200 bg-neutral-50 p-4">
						<input type="checkbox" id="contact-consent" name="contactConsent" class="mt-1 h-4 w-4 rounded border-neutral-300 text-azento-600 focus:ring-azento-500" required />
						<label for="contact-consent" class="text-xs leading-relaxed text-neutral-600">
							He leído la <a href="/politica-privacidad" class="font-semibold text-azento-700 underline underline-offset-2 hover:text-azento-500">política de privacidad</a> y acepto el tratamiento de mis datos para responder a esta solicitud. *
						</label>
					</div>

					<div class="hidden rounded-lg border p-4" role="status" aria-live="polite" data-form-status>
						<p class="font-semibold" data-status-title></p>
						<p class="mt-1 text-sm" data-status-message></p>
					</div>

					<button type="submit" class:list={["flex min-h-12 w-full items-center justify-center gap-3 rounded-lg px-6 py-3 font-semibold text-white transition-colors disabled:cursor-not-allowed disabled:opacity-65", isWood ? "bg-accent-700 hover:bg-accent-600" : "bg-azento-700 hover:bg-azento-600"]} data-submit-button>
						<span data-button-text>Enviar solicitud</span>
						<Send size={19} data-button-icon aria-hidden="true" />
						<span class="hidden h-5 w-5 animate-spin rounded-full border-2 border-white/35 border-t-white" data-button-spinner aria-hidden="true"></span>
					</button>
				</form>
			</div>
		</div>
	</div>
</section>

<script>
	const form = document.querySelector<HTMLFormElement>("[data-quote-form]");
	const submitButton = form?.querySelector<HTMLButtonElement>("[data-submit-button]");
	const buttonText = form?.querySelector<HTMLElement>("[data-button-text]");
	const buttonIcon = form?.querySelector<HTMLElement>("[data-button-icon]");
	const buttonSpinner = form?.querySelector<HTMLElement>("[data-button-spinner]");
	const status = form?.querySelector<HTMLElement>("[data-form-status]");
	const statusTitle = form?.querySelector<HTMLElement>("[data-status-title]");
	const statusMessage = form?.querySelector<HTMLElement>("[data-status-message]");
	const sourceUrl = form?.querySelector<HTMLInputElement>("[data-source-url]");

	const setSourceUrl = () => {
		if (sourceUrl) sourceUrl.value = window.location.href;
	};

	const setLoading = (loading: boolean) => {
		if (submitButton) submitButton.disabled = loading;
		if (buttonText) buttonText.textContent = loading ? "Enviando..." : "Enviar solicitud";
		buttonIcon?.classList.toggle("hidden", loading);
		buttonSpinner?.classList.toggle("hidden", !loading);
	};

	const showStatus = (type: "success" | "error", message: string) => {
		if (!status || !statusTitle || !statusMessage) return;
		const isSuccess = type === "success";
		status.className = `rounded-lg border p-4 ${isSuccess ? "border-green-200 bg-green-50 text-green-800" : "border-red-200 bg-red-50 text-red-800"}`;
		statusTitle.textContent = isSuccess ? "Solicitud enviada" : "No se ha podido enviar";
		statusMessage.textContent = message;
		status.scrollIntoView({ behavior: "smooth", block: "nearest" });
	};

	setSourceUrl();

	form?.addEventListener("submit", async (event) => {
		event.preventDefault();
		setSourceUrl();
		setLoading(true);
		status?.classList.add("hidden");

		const formData = new FormData(form);
		const data = {
			name: String(formData.get("name") ?? ""),
			email: String(formData.get("email") ?? ""),
			phone: String(formData.get("phone") ?? ""),
			service: String(formData.get("service") ?? ""),
			message: String(formData.get("message") ?? ""),
			business_unit: String(formData.get("business_unit") ?? ""),
			source_page: String(formData.get("source_page") ?? ""),
			source_url: String(formData.get("source_url") ?? ""),
			honeypot: String(formData.get("website") ?? ""),
		};

		try {
			const response = await fetch("/api/quote.php", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(data),
			});
			const contentType = response.headers.get("content-type") ?? "";
			const result = contentType.includes("application/json") ? await response.json() : null;

			if (response.ok && result?.ok) {
				showStatus("success", "Gracias. Te contactaremos lo antes posible.");
				form.reset();
				setSourceUrl();
			} else {
				showStatus("error", result?.error ?? "Inténtalo de nuevo en unos minutos.");
			}
		} catch {
			const isLocal = ["localhost", "127.0.0.1", "::1"].includes(window.location.hostname);
			showStatus("error", isLocal ? "El formulario necesita un servidor PHP para probarse en local." : "El formulario no está disponible ahora mismo. Inténtalo de nuevo en unos minutos.");
		} finally {
			setLoading(false);
		}
	});
</script>
