---
import { ArrowDown, ArrowRight } from "lucide-react";
import { siteCopy, type BusinessUnitConfig } from "../lib/cms";

interface Props {
	unit: BusinessUnitConfig;
}

const { unit } = Astro.props;
const isWood = unit.tone === "wood";
---

<section id="inicio" class="relative flex min-h-[680px] items-end overflow-hidden pb-16 pt-32 sm:min-h-[720px] sm:pb-20 lg:min-h-[760px] lg:pb-24">
	<img
		src={unit.heroImage}
		alt={unit.heroAlt}
		class="absolute inset-0 h-full w-full object-cover"
		loading="eager"
		fetchpriority="high"
	/>
	<div class:list={["absolute inset-0", isWood ? "bg-gradient-to-r from-accent-950/90 via-accent-950/60 to-neutral-950/20" : "bg-gradient-to-r from-azento-950/95 via-azento-950/70 to-neutral-950/25"]}></div>
	<div class="absolute inset-0 bg-gradient-to-t from-neutral-950/70 via-transparent to-neutral-950/20"></div>

	<div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class:list={["mb-5 text-sm font-semibold uppercase tracking-widest", isWood ? "text-accent-300" : "text-azento-200"]}>
				{unit.heroEyebrow}
			</p>
			<h1 class="font-display text-4xl font-semibold leading-[1.08] text-white sm:text-5xl lg:text-7xl">
				{unit.heroTitle}
			</h1>
			<p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-200 sm:text-xl">
				{unit.heroDescription}
			</p>

			<div class="mt-9 flex flex-col items-start gap-3 sm:flex-row">
				<a href="#presupuesto" class:list={["inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-lg px-6 py-3 font-semibold transition-colors sm:w-auto", isWood ? "bg-accent-400 text-neutral-950 hover:bg-accent-300" : "bg-white text-azento-900 hover:bg-neutral-100"]}>
					{siteCopy.businessPage.heroQuoteLabel}
					<ArrowRight size={19} aria-hidden="true" />
				</a>
				<a href="#proyectos" class="inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-lg border border-white/50 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto">
					{siteCopy.businessPage.heroProjectsLabel}
					<ArrowDown size={18} aria-hidden="true" />
				</a>
			</div>
		</div>

		<ul class="mt-12 flex flex-wrap gap-x-6 gap-y-3 border-t border-white/20 pt-6 text-sm text-white/75 sm:gap-x-9">
			{unit.services.slice(0, 4).map((service) => <li>{service.title}</li>)}
		</ul>
	</div>
</section>
