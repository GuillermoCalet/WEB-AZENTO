---
import { ArrowRight, Check } from "lucide-react";
import type { BusinessUnitConfig } from "../data/businessUnits";

interface Props {
	unit: BusinessUnitConfig;
}

const { unit } = Astro.props;
const isWood = unit.tone === "wood";
---

<section id="proceso" class="bg-white py-20 sm:py-24 lg:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-20">
			<div>
				<p class:list={["mb-4 text-sm font-semibold uppercase tracking-widest", isWood ? "text-accent-700" : "text-azento-600"]}>
					Cómo trabajamos
				</p>
				<h2 class="font-display text-3xl font-semibold leading-tight text-azento-800 sm:text-4xl lg:text-5xl">
					{unit.processTitle}
				</h2>
				<p class="mt-6 max-w-xl text-lg leading-relaxed text-neutral-600">
					{unit.processDescription}
				</p>
			</div>

			<ol class="grid gap-px overflow-hidden rounded-lg border border-neutral-200 bg-neutral-200 sm:grid-cols-2">
				{unit.process.map((step, index) => (
					<li class="min-h-52 bg-neutral-50 p-7 sm:p-8">
						<span class:list={["text-sm font-bold", isWood ? "text-accent-700" : "text-azento-600"]}>
							{String(index + 1).padStart(2, "0")}
						</span>
						<h3 class="mt-8 font-display text-2xl font-semibold text-azento-800">{step.title}</h3>
						<p class="mt-3 leading-relaxed text-neutral-600">{step.description}</p>
					</li>
				))}
			</ol>
		</div>
	</div>
</section>

<section class:list={["py-20 sm:py-24", isWood ? "bg-accent-50" : "bg-azento-50"]}>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr] lg:gap-20">
			<h2 class="max-w-xl font-display text-3xl font-semibold leading-tight text-azento-800 sm:text-4xl">
				{unit.trustTitle}
			</h2>
			<div class="grid gap-8 md:grid-cols-3">
				{unit.trust.map((item) => (
					<div>
						<div class:list={["flex h-10 w-10 items-center justify-center rounded-lg", isWood ? "bg-accent-600 text-white" : "bg-azento-600 text-white"]}>
							<Check size={20} strokeWidth={2.2} aria-hidden="true" />
						</div>
						<h3 class="mt-5 text-lg font-semibold text-azento-800">{item.title}</h3>
						<p class="mt-2 leading-relaxed text-neutral-600">{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<section class:list={["relative overflow-hidden py-16 sm:py-20", isWood ? "bg-accent-800" : "bg-azento-800"]}>
	<div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
		<div>
			<p class="text-sm font-semibold uppercase tracking-widest text-white/70">Tu proyecto empieza aquí</p>
			<h2 class="mt-3 max-w-3xl font-display text-3xl font-semibold text-white sm:text-4xl">
				Hablemos del espacio que quieres transformar
			</h2>
		</div>
		<a
			href="#presupuesto"
			class="inline-flex min-h-12 shrink-0 items-center gap-3 rounded-lg bg-white px-6 py-3 font-semibold text-azento-900 transition-colors hover:bg-neutral-100"
		>
			Solicitar presupuesto
			<ArrowRight size={19} aria-hidden="true" />
		</a>
	</div>
</section>
