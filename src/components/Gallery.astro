---
import { ChevronLeft, ChevronRight, Expand, X } from "lucide-react";
import { siteCopy, type BusinessUnitConfig } from "../lib/cms";

interface Props {
	unit: BusinessUnitConfig;
}

const { unit } = Astro.props;
const isWood = unit.tone === "wood";
const firstProject = unit.projects[0];
const copy = siteCopy.businessPage;
---

<section id="proyectos" class:list={["py-20 text-white sm:py-24 lg:py-28", isWood ? "bg-accent-950" : "bg-azento-900"]}>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end lg:gap-16">
			<div>
				<p class:list={["mb-4 text-sm font-semibold uppercase tracking-widest", isWood ? "text-accent-300" : "text-azento-200"]}>
					{siteCopy.navigation.projectsLabel}
				</p>
				<h2 class="font-display text-3xl font-semibold leading-tight text-white sm:text-4xl lg:text-5xl">
					{unit.projectsTitle}
				</h2>
			</div>
			<p class="max-w-2xl text-lg leading-relaxed text-white/70 lg:justify-self-end">
				{unit.projectsDescription}
			</p>
		</div>

		{unit.projects.length === 0 && (
			<p class="mt-12 rounded-lg border border-white/20 p-6 text-center text-white/70">{copy.projectsEmptyText}</p>
		)}

		<div class="mt-12 grid auto-rows-[18rem] gap-3 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3 lg:auto-rows-[20rem]">
			{unit.projects.map((project, index) => (
				<button
					type="button"
					class:list={[
						"group relative overflow-hidden rounded-lg text-left",
						index === 0 ? "sm:col-span-2 lg:row-span-2 lg:min-h-[41rem]" : "",
					]}
					data-project-trigger
					data-project-index={index}
					aria-label={`${copy.galleryOpenImageAriaPrefix} ${project.title}`}
				>
					<img
						src={project.image}
						alt={project.alt}
						class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
						style={`object-position: ${project.objectPosition ?? "center"};`}
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-neutral-950/90 via-neutral-950/10 to-transparent"></div>
					<div class="absolute inset-x-0 bottom-0 p-5 sm:p-6">
						<p class:list={["text-xs font-semibold uppercase tracking-widest", isWood ? "text-accent-300" : "text-azento-200"]}>{project.category}</p>
						<h3 class="mt-2 font-display text-xl font-semibold text-white sm:text-2xl">{project.title}</h3>
					</div>
					<span class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-lg bg-neutral-950/55 text-white opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100">
						<Expand size={18} aria-hidden="true" />
					</span>
				</button>
			))}
		</div>
	</div>

	<div
		id="project-lightbox"
		class="fixed inset-0 z-[100] hidden items-center justify-center bg-neutral-950/95 p-4 backdrop-blur-sm sm:p-8"
		role="dialog"
		aria-modal="true"
		aria-labelledby="lightbox-title"
		data-projects={JSON.stringify(unit.projects)}
	>
		<button type="button" class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-lg border border-white/25 bg-neutral-950/60 text-white hover:bg-neutral-800 sm:right-6 sm:top-6" aria-label={copy.galleryCloseImageAriaLabel} data-lightbox-close>
			<X size={22} aria-hidden="true" />
		</button>
		<button type="button" class="absolute left-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-lg border border-white/25 bg-neutral-950/60 text-white hover:bg-neutral-800 sm:left-6" aria-label={copy.galleryPreviousImageAriaLabel} data-lightbox-prev>
			<ChevronLeft size={24} aria-hidden="true" />
		</button>

		<figure class="flex h-full w-full max-w-6xl flex-col items-center justify-center gap-4 px-10">
			<img
				class="max-h-[78vh] max-w-full rounded-lg object-contain shadow-2xl"
				src={firstProject?.image ?? unit.heroImage}
				alt={firstProject?.alt ?? ""}
				data-lightbox-image
			/>
			<figcaption class="text-center">
				<p class:list={["text-xs font-semibold uppercase tracking-widest", isWood ? "text-accent-300" : "text-azento-200"]} data-lightbox-category></p>
				<h3 id="lightbox-title" class="mt-2 font-display text-2xl font-semibold text-white" data-lightbox-title></h3>
			</figcaption>
		</figure>

		<button type="button" class="absolute right-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-lg border border-white/25 bg-neutral-950/60 text-white hover:bg-neutral-800 sm:right-6" aria-label={copy.galleryNextImageAriaLabel} data-lightbox-next>
			<ChevronRight size={24} aria-hidden="true" />
		</button>
	</div>
</section>

<script>
	type LightboxProject = {
		title: string;
		category: string;
		image: string;
		alt: string;
	};

	const lightbox = document.getElementById("project-lightbox");
	const triggers = document.querySelectorAll<HTMLButtonElement>("[data-project-trigger]");
	const lightboxImage = lightbox?.querySelector<HTMLImageElement>("[data-lightbox-image]");
	const lightboxTitle = lightbox?.querySelector<HTMLElement>("[data-lightbox-title]");
	const lightboxCategory = lightbox?.querySelector<HTMLElement>("[data-lightbox-category]");
	const closeButton = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-close]");
	const previousButton = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
	const nextButton = lightbox?.querySelector<HTMLButtonElement>("[data-lightbox-next]");
	const projects: LightboxProject[] = JSON.parse(lightbox?.dataset.projects ?? "[]");
	let activeIndex = 0;
	let lastFocused: HTMLElement | null = null;

	const showProject = (index: number) => {
		const project = projects[index];
		if (!project || !lightboxImage || !lightboxTitle || !lightboxCategory) return;

		activeIndex = index;
		lightboxImage.src = project.image;
		lightboxImage.alt = project.alt;
		lightboxTitle.textContent = project.title;
		lightboxCategory.textContent = project.category;
	};

	const openLightbox = (index: number) => {
		if (!lightbox || projects.length === 0) return;
		lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
		showProject(index);
		lightbox.classList.remove("hidden");
		lightbox.classList.add("flex");
		document.body.classList.add("overflow-hidden");
		closeButton?.focus();
	};

	const closeLightbox = () => {
		lightbox?.classList.add("hidden");
		lightbox?.classList.remove("flex");
		document.body.classList.remove("overflow-hidden");
		lastFocused?.focus();
	};

	const showPrevious = () => showProject((activeIndex - 1 + projects.length) % projects.length);
	const showNext = () => showProject((activeIndex + 1) % projects.length);

	triggers.forEach((trigger) => {
		trigger.addEventListener("click", () => openLightbox(Number(trigger.dataset.projectIndex ?? 0)));
	});
	closeButton?.addEventListener("click", closeLightbox);
	previousButton?.addEventListener("click", showPrevious);
	nextButton?.addEventListener("click", showNext);
	lightbox?.addEventListener("click", (event) => {
		if (event.target === lightbox) closeLightbox();
	});

	document.addEventListener("keydown", (event) => {
		if (!lightbox || lightbox.classList.contains("hidden")) return;
		if (event.key === "Escape") closeLightbox();
		if (event.key === "ArrowLeft") showPrevious();
		if (event.key === "ArrowRight") showNext();
	});
</script>
