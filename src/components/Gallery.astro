---
/**
 * Gallery.astro - Galería de proyectos con Bento Grid
 * Diseño asimétrico moderno y responsive
 */

// Datos de la galería - Fácil de editar
const sectionData = {
	tagline: "Nuestros Proyectos",
	headline: "Espacios que inspiran",
	description: "Cada proyecto es una obra de arte única. Descubre cómo transformamos espacios ordinarios en refugios extraordinarios.",
};

type Project = {
	id: number;
	title: string;
	category: string;
	location: string;
	image: string;
	size: "large" | "medium" | "small";
	objectPosition?: string;
};

// Proyectos reales de AZento
const projects: Project[] = [
	{
		id: 1,
		title: "Fachada con madera tecnológica",
		category: "Fachada y Revestimientos",
		location: "Madrid",
		image: "/images/jardin_madera_tecnologica.JPEG",
		size: "large", // Ocupa más espacio en el grid
	},
	{
		id: 2,
		title: "Decoración exterior",
		category: "Jardines y Terrazas",
		location: "Madrid",
		image: "/images/decoracion_2.JPG",
		size: "small",
	},
	{
		id: 3,
		title: "Pérgola Madera",
		category: "Pérgolas y Celosías",
		location: "Madrid",
		image: "/images/jardin marisa_pergola.JPG",
		size: "small",
	},
	{
		id: 4,
		title: "Revestimiento Porcelánico",
		category: "Fachadas y Revestimientos",
		location: "Madrid",
		image: "/images/revestimiento_fachada_porcelanic.JPG",
		size: "medium",
	},
	{
		id: 5,
		title: "Cocina Premium",
		category: "Reforma Exterior",
		location: "Madrid",
		image: "/images/cocina_exterior_premium.jpeg",
		size: "medium",
	},
	{
		id: 6,
		title: "Exterior Relajante",
		category: "Jardines y Terrazas",
		location: "Madrid",
		image: "/images/jacuzzi_exterior.jpeg",
		size: "medium",
		objectPosition: "center 40%",
	},
];
---

<section id="proyectos" class="py-24 lg:py-32 bg-azento-700 relative overflow-hidden">
	<!-- Decorative elements -->
	<div class="absolute inset-0 opacity-5">
		<div class="absolute top-0 left-1/4 w-96 h-96 bg-accent-400 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-1/4 w-64 h-64 bg-azento-400 rounded-full blur-3xl"></div>
	</div>

	<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
			<!-- Tagline -->
			<span class="inline-block text-accent-400 font-medium text-sm tracking-widest uppercase mb-4">
				{sectionData.tagline}
			</span>
			
			<!-- Headline -->
			<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-white mb-6">
				{sectionData.headline}
			</h2>
			
			<!-- Description -->
			<p class="text-lg text-neutral-200/80 leading-relaxed">
				{sectionData.description}
			</p>
		</div>

		<!-- Bento Grid Gallery -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 auto-rows-[200px] lg:auto-rows-[250px]">
			{projects.map((project, index) => {
				// Definir clases de tamaño para el bento grid
				const sizeClasses = {
					large: "sm:col-span-2 sm:row-span-2",
					medium: "sm:col-span-2 lg:col-span-2 sm:row-span-1",
					small: "sm:col-span-1 sm:row-span-1",
				};
				
				return (
					<article 
						class={`group relative rounded-2xl lg:rounded-3xl overflow-hidden cursor-pointer focus:outline-none focus:ring-2 focus:ring-accent-400 focus:ring-offset-4 focus:ring-offset-azento-700
							${sizeClasses[project.size as keyof typeof sizeClasses]}`}
						role="button"
						tabindex="0"
						aria-label={`Ver imagen ampliada de ${project.title}`}
						data-lightbox-trigger
						data-project-index={index}
					>
						<!-- Image -->
						<img 
							src={project.image}
							alt={project.title}
							class="absolute inset-0 w-full h-full object-cover 
								transition-transform duration-700 group-hover:scale-110"
							style={`object-position: ${project.objectPosition ?? "center"};`}
							loading="lazy"
						/>
						
						<!-- Overlay Gradient -->
						<div class="absolute inset-0 bg-gradient-to-t from-azento-950/90 via-azento-900/20 to-transparent 
							opacity-60 group-hover:opacity-80 transition-opacity duration-300">
						</div>
						
						<!-- Content -->
						<div class="absolute inset-0 p-6 lg:p-8 flex flex-col justify-end">
							<!-- Category Badge -->
							<span class="inline-flex self-start px-3 py-1 bg-accent-400/90 text-neutral-900 
								text-xs font-semibold rounded-full mb-3
								transform -translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
								transition-all duration-300">
								{project.category}
							</span>
							
							<!-- Title -->
							<h3 class="font-display text-xl lg:text-2xl font-semibold text-white mb-1
								transform group-hover:-translate-y-1 transition-transform duration-300">
								{project.title}
							</h3>
							
							<!-- Location -->
							<div class="flex items-center gap-2 text-neutral-300 text-sm
								transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
								transition-all duration-300 delay-75">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
										d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
										d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
								</svg>
								{project.location}
							</div>
							
							<!-- View Project Icon -->
							<div class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm
								flex items-center justify-center border border-white/20
								transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100
								transition-all duration-300 hover:bg-white/20">
								<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
										d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
								</svg>
							</div>
						</div>
						
						<!-- Subtle border on hover -->
						<div class="absolute inset-0 border-2 border-accent-400/0 rounded-2xl lg:rounded-3xl
							group-hover:border-accent-400/30 transition-colors duration-300">
						</div>
					</article>
				);
			})}
		</div>

		<!-- CTA Button -->
		<div class="mt-12 lg:mt-16 text-center">
			<a 
				href="#contacto"
				class="inline-flex items-center gap-3 bg-transparent text-white 
					px-8 py-4 rounded-full font-semibold border-2 border-accent-400/50
					hover:bg-accent-400 hover:text-neutral-900 hover:border-accent-400
					transition-all duration-300 group"
			>
				Más información 
				<svg 
					class="w-5 h-5 group-hover:translate-x-1 transition-transform" 
					fill="none" 
					stroke="currentColor" 
					viewBox="0 0 24 24"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
				</svg>
			</a>
		</div>
	</div>

	<div 
		id="project-lightbox"
		class="fixed inset-0 z-[100] hidden items-center justify-center bg-azento-950/95 px-4 py-6 backdrop-blur-sm sm:px-6 lg:px-10"
		role="dialog"
		aria-modal="true"
		aria-labelledby="project-lightbox-title"
		data-project-lightbox
		data-projects={JSON.stringify(projects)}
	>
		<button
			type="button"
			class="absolute right-4 top-4 z-[101] inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white backdrop-blur-sm transition-colors hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-accent-400 sm:right-6 sm:top-6"
			aria-label="Cerrar imagen"
			data-lightbox-close
		>
			<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>

		<button
			type="button"
			class="absolute left-3 top-1/2 z-[101] inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white backdrop-blur-sm transition-colors hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-accent-400 sm:left-6 sm:h-12 sm:w-12"
			aria-label="Imagen anterior"
			data-lightbox-prev
		>
			<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
			</svg>
		</button>

		<figure class="pointer-events-none flex h-full w-full max-w-6xl flex-col items-center justify-center gap-4 px-10 sm:gap-5">
			<img
				id="project-lightbox-image"
				class="pointer-events-auto max-h-[72vh] max-w-full rounded-2xl object-contain shadow-2xl sm:max-h-[78vh]"
				src=""
				alt=""
				data-lightbox-image
			/>
			<figcaption class="pointer-events-auto text-center">
				<p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent-400" data-lightbox-category></p>
				<h3 id="project-lightbox-title" class="font-display text-2xl font-semibold text-white sm:text-3xl" data-lightbox-title></h3>
			</figcaption>
		</figure>

		<button
			type="button"
			class="absolute right-3 top-1/2 z-[101] inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white backdrop-blur-sm transition-colors hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-accent-400 sm:right-6 sm:h-12 sm:w-12"
			aria-label="Imagen siguiente"
			data-lightbox-next
		>
			<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
			</svg>
		</button>
	</div>
</section>

<script>
	type LightboxProject = {
		title: string;
		category: string;
		location: string;
		image: string;
	};

	const lightbox = document.querySelector<HTMLElement>("[data-project-lightbox]");
	const triggers = document.querySelectorAll<HTMLElement>("[data-lightbox-trigger]");
	const image = document.querySelector<HTMLImageElement>("[data-lightbox-image]");
	const title = document.querySelector<HTMLElement>("[data-lightbox-title]");
	const category = document.querySelector<HTMLElement>("[data-lightbox-category]");
	const closeButton = document.querySelector<HTMLButtonElement>("[data-lightbox-close]");
	const previousButton = document.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
	const nextButton = document.querySelector<HTMLButtonElement>("[data-lightbox-next]");

	if (lightbox && image && title && category) {
		const projects: LightboxProject[] = JSON.parse(lightbox.dataset.projects ?? "[]");
		let activeIndex = 0;
		let lastFocusedElement: HTMLElement | null = null;

		const updateLightbox = (index: number) => {
			const project = projects[index];

			if (!project) return;

			activeIndex = index;
			image.src = project.image;
			image.alt = project.title;
			title.textContent = project.title;
			category.textContent = project.category;
		};

		const openLightbox = (index: number) => {
			lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
			updateLightbox(index);
			lightbox.classList.remove("hidden");
			lightbox.classList.add("flex");
			document.body.classList.add("overflow-hidden");
			closeButton?.focus();
		};

		const closeLightbox = () => {
			lightbox.classList.add("hidden");
			lightbox.classList.remove("flex");
			document.body.classList.remove("overflow-hidden");
			lastFocusedElement?.focus();
		};

		const showPrevious = () => {
			const previousIndex = (activeIndex - 1 + projects.length) % projects.length;
			updateLightbox(previousIndex);
		};

		const showNext = () => {
			const nextIndex = (activeIndex + 1) % projects.length;
			updateLightbox(nextIndex);
		};

		triggers.forEach((trigger) => {
			const openFromTrigger = () => {
				const index = Number(trigger.dataset.projectIndex ?? 0);
				openLightbox(index);
			};

			trigger.addEventListener("click", openFromTrigger);
			trigger.addEventListener("keydown", (event) => {
				if (event.key === "Enter" || event.key === " ") {
					event.preventDefault();
					openFromTrigger();
				}
			});
		});

		closeButton?.addEventListener("click", closeLightbox);
		previousButton?.addEventListener("click", showPrevious);
		nextButton?.addEventListener("click", showNext);

		lightbox.addEventListener("click", (event) => {
			if (event.target === lightbox) {
				closeLightbox();
			}
		});

		document.addEventListener("keydown", (event) => {
			if (lightbox.classList.contains("hidden")) return;

			if (event.key === "Escape") closeLightbox();
			if (event.key === "ArrowLeft") showPrevious();
			if (event.key === "ArrowRight") showNext();
		});
	}
</script>
