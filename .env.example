# ===================================
# Variable pública de analítica (opcional)
# ===================================
# Es pública por diseño y solo se usa después del consentimiento.
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===================================
# Configuración de Email (SMTP genérico)
# ===================================
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@tudominio.com
SMTP_PASSWORD=tu-password-smtp
MAIL_FROM=tu-email@tudominio.com
NOTIFY_EMAIL_TO=tu-email-notificaciones@gmail.com

# ===================================
# Configuración de Twilio (WhatsApp)
# ===================================
ENABLE_WHATSAPP=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+34XXXXXXXXX

# El CMS no usa secretos en Astro.
# GITHUB_OAUTH_ID y GITHUB_OAUTH_SECRET se guardan en Cloudflare Workers.
# ARSYS_* se guardan en GitHub Actions Secrets.
